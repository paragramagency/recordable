# Defaults for a folder of documents. Copy to `.env` beside your document (it is
# loaded automatically) and fill in. Anything spelled out in a document's
# frontmatter — or passed explicitly in code / on the CLI — overrides these, so a
# document stays fully reproducible by spelling its values out.

# ── Voiceover credentials + defaults ─────────────────────────────────────────
# With these set, a Markdown file opts into voiceover with just `voiceover: true`
# in its frontmatter — no provider/voice repeated per file.

# ElevenLabs API key (required for real synthesis). Not a "default" — a secret —
# so it keeps its provider name.
ELEVENLABS_API_KEY=

DEFAULT_TTS_PROVIDER=elevenlabs   # or `mock` for silent, offline audio
DEFAULT_VOICE_ID=
DEFAULT_MODEL_ID=eleven_multilingual_v2

# ── Recording config defaults ────────────────────────────────────────────────
# Every recording-config option can be defaulted here as DEFAULT_<UPPER_SNAKE>
# (fps → DEFAULT_FPS, outputDir → DEFAULT_OUTPUT_DIR). A few common ones:

# DEFAULT_VIEWPORT=1920x1080
# DEFAULT_FPS=30
# DEFAULT_HEADLESS=false
# DEFAULT_OUTPUT_DIR=output
# DEFAULT_LAUNCH_ARGS=--no-sandbox,--disable-dev-shm-usage
