# Voiceover credentials + defaults. Copy to `.env` beside your document (it is
# loaded automatically) and fill in. With these set, a Markdown file opts into
# voiceover with just `voiceover: true` in its frontmatter — no provider/voice
# repeated per file. Anything spelled out in frontmatter overrides these.

# ElevenLabs API key (required for real synthesis).
ELEVENLABS_API_KEY=

# Defaults applied when frontmatter omits them.
RECORDABLE_TTS_PROVIDER=elevenlabs   # or `mock` for silent, offline audio
RECORDABLE_VOICE_ID=
RECORDABLE_MODEL_ID=eleven_multilingual_v2
