{
  "name": "recordable",
  "version": "0.7.0",
  "description": "Programmatic, repeatable browser screen recording. Script a walkthrough as a fluent chain of actions — clicks, typing, smooth zoom/scroll, an animated cursor, and manual steps like logins — and capture it to MP4.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paragramagency/recordable.git"
  },
  "homepage": "https://github.com/paragramagency/recordable#readme",
  "bugs": {
    "url": "https://github.com/paragramagency/recordable/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "recordable": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./voiceover": {
      "types": "./dist/voiceover/index.d.ts",
      "import": "./dist/voiceover/index.js"
    }
  },
  "files": [
    "dist",
    "recordable.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "tsx --test test/*.test.ts",
    "test:e2e": "tsx --test test/e2e/*.e2e.ts",
    "clean": "rm -rf dist",
    "gen:schema": "tsx scripts/gen-schema.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run clean && npm run gen:schema && npm run build",
    "commitlint": "commitlint",
    "prepare": "husky && git config commit.template .gitmessage 2>/dev/null || true"
  },
  "keywords": [
    "screen-recording",
    "screencast",
    "screen-capture",
    "recorder",
    "puppeteer",
    "automation",
    "browser",
    "scripted",
    "video",
    "mp4"
  ],
  "author": "Cam Parry <hello@camparry.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "markdown-it": "^14.2.0",
    "puppeteer": "^25.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "optionalDependencies": {
    "@elevenlabs/elevenlabs-js": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": "prettier --write"
  }
}
